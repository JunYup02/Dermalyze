GEMINI_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=
VERTEX_ENDPOINT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_PLACES_API_KEY=

# --- Auth / lesion body-part ---
# DB 접속 문자열 (PostgreSQL 준비되면 값을 채우세요). 비워두면 로컬 개발용 SQLite(dermalyze.db)로 대체됨.
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/dermalyze

SECRET_KEY=change-this-to-a-random-secret-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS 허용 도메인 (콤마로 구분, 개발 중엔 * 허용)
CORS_ALLOWED_ORIGINS=*
